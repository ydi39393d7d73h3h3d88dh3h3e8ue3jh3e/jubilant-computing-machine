<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuxAutoSpa — Премиальный детейлинг</title>
    <!-- Шрифты и Font Awesome -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #0b0b0b;
            color: #e0e0e0;
            line-height: 1.5;
            scroll-behavior: smooth;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        @media (min-width: 1257px) {
            .container {
                padding: 0 20px;
            }
        }

        h1, h2, h3 {
            font-weight: 600;
            letter-spacing: -0.02em;
        }

        h1 {
            font-size: 3.2rem;
            line-height: 1.2;
            background: linear-gradient(135deg, #fff 0%, #b0b0b0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        h2 {
            font-size: 2.4rem;
            margin-bottom: 40px;
            position: relative;
            display: inline-block;
        }
        h2:after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 80px;
            height: 4px;
            background: #d4a13e;
            border-radius: 2px;
        }

        h3 {
            font-size: 1.5rem;
            margin-bottom: 20px;
            color: #fff;
        }

        .header {
            padding: 20px 0;
            border-bottom: 1px solid #2a2a2a;
            background: rgba(11, 11, 11, 0.95);
            backdrop-filter: blur(8px);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }
        .logo {
            font-size: 1.8rem;
            font-weight: 700;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .logo span {
            color: #d4a13e;
        }
        .header-info {
            display: flex;
            align-items: center;
            gap: 30px;
        }
        .header-phone {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #fff;
            font-weight: 600;
            font-size: 1.2rem;
            transition: color 0.2s;
            text-decoration: none;
        }
        .header-phone i {
            color: #d4a13e;
        }
        .header-phone:hover {
            color: #d4a13e;
        }
        .whatsapp-btn {
            background: #25D366;
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 40px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            font-size: 1rem;
        }
        .whatsapp-btn i {
            font-size: 1.2rem;
        }
        .whatsapp-btn:hover {
            background: #20b859;
            transform: scale(1.02);
        }

        /* Hero секция с галереей */
        .hero {
            padding: 60px 0 40px;
        }
        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }
        .hero p {
            font-size: 1.2rem;
            color: #aaa;
            margin: 24px 0 32px;
            max-width: 500px;
        }
        .hero-stats {
            display: flex;
            gap: 30px;
            margin-top: 30px;
        }
        .stat-item {
            display: flex;
            flex-direction: column;
        }
        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: #d4a13e;
        }

        /* Виджет Яндекса (твой исправленный) */
        .yandex-premium-widget {
            background: rgba(20, 20, 20, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(212, 161, 62, 0.2);
            border-radius: 80px;
            padding: 8px;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.5);
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        @media (min-width: 1257px) {
            .yandex-premium-widget {
                padding: 20px;
            }
        }

        .yandex-icon-bg {
            background: #FF3E3E;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.6rem;
            box-shadow: 0 5px 15px rgba(255, 62, 62, 0.3);
            flex-shrink: 0;
        }

        .yandex-rating {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.05);
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid rgba(255,255,255,0.05);
            flex-shrink: 0;
        }

        .yandex-stars {
            color: #FFD700;
            letter-spacing: 2px;
            font-size: 1rem;
        }

        .yandex-score {
            font-weight: 700;
            color: white;
            margin-left: 4px;
        }

        .yandex-reviews-count {
            color: #999;
            font-size: 0.9rem;
        }

        .yandex-cta {
            background: linear-gradient(135deg, #d4a13e, #b48a2f);
            color: #0b0b0b;
            padding: 10px 24px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
            font-size: 0.95rem;
            white-space: nowrap;
            flex-grow: 1;
            justify-content: center;
        }

        .yandex-cta:hover {
            background: linear-gradient(135deg, #e0b050, #c79b3a);
            transform: translateX(3px);
        }

        /* Галерея в hero */
        .hero-gallery {
            background: #1a1a1a;
            border-radius: 30px;
            padding: 20px;
            border: 1px solid #2a2a2a;
        }

        .gallery-main {
            width: 100%;
            aspect-ratio: 4/3;
            border-radius: 20px;
            overflow: hidden;
            cursor: pointer;
            margin-bottom: 16px;
            background: #131313;
        }

        .gallery-main img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }

        .gallery-main:hover img {
            transform: scale(1.02);
        }

        .gallery-thumbnails {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        .thumbnail {
            aspect-ratio: 1/1;
            border-radius: 12px;
            overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: 0.2s;
            opacity: 0.7;
        }

        .thumbnail.active {
            border-color: #d4a13e;
            opacity: 1;
        }

        .thumbnail:hover {
            opacity: 1;
        }

        .thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Lightbox (полноэкранный просмотр) */
        .lightbox {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(10px);
        }

        .lightbox.active {
            display: flex;
        }

        .lightbox-content {
            position: relative;
            width: 90%;
            height: 90%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .lightbox-image {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            cursor: zoom-in;
            transition: transform 0.2s;
        }

        .lightbox-image.zoomed {
            cursor: zoom-out;
            transform: scale(1.5);
        }

        .lightbox-close {
            position: absolute;
            top: 20px;
            right: 30px;
            color: #fff;
            font-size: 2rem;
            cursor: pointer;
            z-index: 1001;
            width: 50px;
            height: 50px;
            background: rgba(0,0,0,0.5);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
        }

        .lightbox-close:hover {
            background: #d4a13e;
            color: #0b0b0b;
        }

        .lightbox-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 50px;
            height: 50px;
            background: rgba(212, 161, 62, 0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            transition: 0.2s;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(212, 161, 62, 0.3);
        }

        .lightbox-nav:hover {
            background: #d4a13e;
            color: #0b0b0b;
        }

        .lightbox-nav.prev {
            left: 20px;
        }

        .lightbox-nav.next {
            right: 20px;
        }

        .lightbox-counter {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.7);
            padding: 8px 16px;
            border-radius: 40px;
            color: #fff;
            font-size: 0.9rem;
            border: 1px solid rgba(212, 161, 62, 0.3);
        }

        /* Остальные секции (без изменений) */
        .services {
            padding: 80px 0;
        }
        .categories-grid {
            display: flex;
            flex-direction: column;
            gap: 60px;
        }
        .category-block {
            background: #131313;
            border-radius: 32px;
            padding: 40px;
            border: 1px solid #2a2a2a;
        }
        .category-name {
            font-size: 2rem;
            color: #d4a13e;
            margin-bottom: 30px;
            font-weight: 600;
        }
        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }
        .service-card {
            background: #1e1e1e;
            border-radius: 24px;
            padding: 24px;
            transition: transform 0.2s, box-shadow 0.2s;
            border: 1px solid #2a2a2a;
            display: flex;
            flex-direction: column;
        }
        .service-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 30px -10px #00000080;
            border-color: #d4a13e40;
        }
        .service-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 8px;
        }
        .service-desc {
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 16px;
            flex-grow: 1;
        }
        .price-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 16px;
        }
        .price {
            font-size: 1.5rem;
            font-weight: 700;
            color: #d4a13e;
        }
        .order-btn {
            background: transparent;
            border: 1px solid #d4a13e;
            color: #d4a13e;
            padding: 8px 16px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .order-btn i {
            font-size: 0.9rem;
        }
        .order-btn:hover {
            background: #d4a13e;
            color: #0b0b0b;
        }

        .gallery-section {
            padding: 60px 0;
        }
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }
        .gallery-item {
            background: #1e1e1e;
            border-radius: 24px;
            overflow: hidden;
            aspect-ratio: 1 / 0.8;
            border: 1px solid #2a2a2a;
            cursor: pointer;
        }
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }
        .gallery-item:hover img {
            transform: scale(1.05);
        }

        .reviews {
            padding: 60px 0;
            background: #0f0f0f;
        }
        .reviews-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 40px;
        }
        .review-card {
            background: #1a1a1a;
            border-radius: 28px;
            padding: 32px;
            border: 1px solid #2a2a2a;
            transition: 0.2s;
        }
        .review-card:hover {
            border-color: #d4a13e;
        }
        .review-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
        }
        .review-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #2a2a2a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            color: #d4a13e;
            font-weight: 600;
        }
        .review-author h4 {
            color: #fff;
            font-size: 1.2rem;
        }
        .review-date {
            color: #777;
            font-size: 0.9rem;
        }
        .review-text {
            color: #ccc;
            line-height: 1.6;
        }
        .review-likes {
            margin-top: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: #d4a13e;
            font-size: 0.95rem;
        }

        .contacts {
            padding: 60px 0;
        }
        .contacts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
        }
        .info-card {
            background: #1a1a1a;
            border-radius: 32px;
            padding: 40px;
        }
        .info-row {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 28px;
            font-size: 1.1rem;
        }
        .info-row i {
            font-size: 1.6rem;
            color: #d4a13e;
            width: 32px;
        }
        .schedule {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px 20px;
            margin: 20px 0;
        }
        .schedule-day {
            color: #aaa;
        }
        .schedule-time {
            color: #fff;
            font-weight: 500;
        }
        .map-container {
            border-radius: 32px;
            overflow: hidden;
            height: 100%;
            min-height: 400px;
            border: 1px solid #2a2a2a;
        }
        .map-container iframe {
            width: 100%;
            height: 100%;
            display: block;
        }

        .feedback {
            padding: 60px 0;
        }
        .form-card {
            background: #131313;
            border-radius: 32px;
            padding: 50px;
            text-align: center;
            max-width: 700px;
            margin: 0 auto;
            border: 1px solid #2a2a2a;
        }
        .form-group {
            display: flex;
            gap: 16px;
            margin-top: 32px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .form-input {
            flex: 1 1 250px;
            padding: 16px 24px;
            border-radius: 50px;
            border: 1px solid #2a2a2a;
            background: #1e1e1e;
            color: #fff;
            font-size: 1rem;
            outline: none;
        }
        .form-input:focus {
            border-color: #d4a13e;
        }
        .form-btn {
            background: #d4a13e;
            border: none;
            padding: 16px 40px;
            border-radius: 50px;
            font-weight: 700;
            color: #0b0b0b;
            cursor: pointer;
            font-size: 1rem;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .form-btn:hover {
            background: #e0b050;
            transform: scale(1.02);
        }

        .footer {
            padding: 30px 0;
            border-top: 1px solid #2a2a2a;
            text-align: center;
            color: #666;
        }

        @media (max-width: 900px) {
            h1 { font-size: 2.4rem; }
            .hero-grid { grid-template-columns: 1fr; }
            .contacts-grid { grid-template-columns: 1fr; }
            .gallery-grid { grid-template-columns: repeat(2, 1fr); }
            .reviews-grid { grid-template-columns: 1fr; }
            .header .container { flex-direction: column; }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="logo">LUX<span>AUTO</span>SPA</div>
            <div class="header-info">
                <a href="tel:+79340040579" class="header-phone"><i class="fas fa-phone-alt"></i> +7 (963) 694-15-15</a>
                <a href="https://wa.me/79636941515?text=Здравствуйте!%20Интересует%20услуга%20детейлинга" target="_blank" class="whatsapp-btn"><i class="fab fa-whatsapp"></i> Написать в WhatsApp</a>
            </div>
        </div>
    </header>

    <main>
        <section class="hero">
            <div class="container hero-grid">
                <div>
                    <!-- Исправленный виджет -->
                    <div class="yandex-premium-widget">
                        <div class="yandex-icon-bg">
                            <i class="fab fa-yandex"></i>
                        </div>
                        <div class="yandex-rating">
                            <span class="yandex-stars">★★★★★</span>
                            <span class="yandex-score">4.9</span>
                            <span class="yandex-reviews-count">• 187 отзывов</span>
                        </div>
                        <a href="https://yandex.ru/maps/-/CPu0nWmW" target="_blank" class="yandex-cta">
                            <span>Смотреть на Я.Карты</span>
                            <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>

                    <h1>Премиальный детейлинг<br>и автохимчистка</h1>
                    <p>Профессиональный уход за автомобилем. Полировка, химчистка, покраска, реставрация и керамическое покрытие.</p>
                    <div class="hero-stats">
                        <div class="stat-item"><span class="stat-number">>500</span> <span>автомобилей</span></div>
                        <div class="stat-item"><span class="stat-number">10 лет</span> <span>опыта</span></div>
                    </div>
                </div>

                <!-- Галерея в hero (справа) -->
                <div class="hero-gallery">
                    <div class="gallery-main" id="heroMainImage">
                        <img src="/assets/images/gallery/1.png" alt="Детейлинг работа" onerror="this.src='https://via.placeholder.com/600x400/1e1e1e/d4a13e?text=1.png'">
                    </div>
                    <div class="gallery-thumbnails" id="heroThumbnails">
                        <div class="thumbnail active" data-index="0"><img src="/assets/images/gallery/1.png" onerror="this.src='https://via.placeholder.com/100x100/1e1e1e/d4a13e?text=1'"></div>
                        <div class="thumbnail" data-index="1"><img src="/assets/images/gallery/2.png" onerror="this.src='https://via.placeholder.com/100x100/1e1e1e/d4a13e?text=2'"></div>
                        <div class="thumbnail" data-index="2"><img src="/assets/images/gallery/3.png" onerror="this.src='https://via.placeholder.com/100x100/1e1e1e/d4a13e?text=3'"></div>
                        <div class="thumbnail" data-index="3"><img src="/assets/images/gallery/4.png" onerror="this.src='https://via.placeholder.com/100x100/1e1e1e/d4a13e?text=4'"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="services" id="services">
            <div class="container">
                <h2>Наши услуги</h2>
                <div class="categories-grid" id="categoriesContainer"></div>
            </div>
        </section>

        <section class="gallery-section">
            <div class="container">
                <h2>Примеры работ</h2>
                <div class="gallery-grid" id="galleryGrid">
                    <!-- Будут добавлены через JS -->
                </div>
            </div>
        </section>

        <section class="reviews">
            <div class="container">
                <h2>Отзывы клиентов</h2>
                <div class="reviews-grid">
                    <div class="review-card">
                        <div class="review-header">
                            <div class="review-avatar">И</div>
                            <div class="review-author">
                                <h4>Иван Лебедев</h4>
                                <div class="review-date">16 октября 2025</div>
                            </div>
                        </div>
                        <p class="review-text">Отдавал сюда машину на химчистку салона. Машина до этого ездила мало, а пылилась много. Много лет. Очистили отлично, внутри снова чисто, нет ни пыли, ни запаха пыли, отличное впечатление. Клиентоориентированность очень заметна, сдавал вообще немного после окончания рабочего дня, получал близко к нему. Молодцы!</p>
                        <div class="review-likes"><i class="fas fa-heart"></i> 150</div>
                    </div>
                    <div class="review-card">
                        <div class="review-header">
                            <div class="review-avatar">А</div>
                            <div class="review-author">
                                <h4>Алексей Рябов</h4>
                                <div class="review-date">17 июня 2025</div>
                            </div>
                        </div>
                        <p class="review-text">Нашел на Авито объявление по перетяжке руля. Списались, потом созвонились, записался на удобное мне время, приехал. Управляющий встретил провел, все показал и рассказал. Я решил чем буду обшивать руль. Мастер вышел быстро снял руль и пошел его перешивать. Два часа заняла работа, вернулся поставил руль, проверили подогрев, кнопки радио, телефон. Все нормально 👍🏻 рассчитался и остался доволен 😊 Рекомендую ребят 👍🏻</p>
                        <div class="review-likes"><i class="fas fa-heart"></i> 429</div>
                    </div>
                    <div class="review-card">
                        <div class="review-header">
                            <div class="review-avatar">Д</div>
                            <div class="review-author">
                                <h4>Дмитрий</h4>
                                <div class="review-date">16 июня 2025</div>
                            </div>
                        </div>
                        <p class="review-text">Оставлял машину на химчистку светлого салона и перешив подушки водителя. Подушку перешили очень аккуратно, подобрали цвет и строчку, очень оперативно и по очень хорошей цене! Салон почистили просто шикарно, обработали все идеально: сиденья, ремни, ворс пола салона, пластик. Машина свежая и чистая внутри. Спасибо!</p>
                        <div class="review-likes"><i class="fas fa-heart"></i> 200</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="contacts">
            <div class="container contacts-grid">
                <div class="info-card">
                    <h3>Контакты</h3>
                    <div class="info-row">
                        <i class="fas fa-map-pin"></i>
                        <span>Каширское шоссе, 23-й километр, вл1с2, посёлок Совхоза имени Ленина</span>
                    </div>
                    <div class="info-row">
                        <i class="fas fa-phone"></i>
                        <a href="tel:+79340040579" style="color:#fff; text-decoration:none;">+7 (963) 694-15-15</a>
                    </div>
                    <div class="info-row">
                        <i class="far fa-clock"></i>
                        <div style="width: 100%;">
                            <div class="schedule">
                                <span class="schedule-day">Пн-Пт</span><span class="schedule-time">10:00 – 20:00</span>
                                <span class="schedule-day">Суббота</span><span class="schedule-time">10:00 – 20:00</span>
                                <span class="schedule-day">Воскресенье</span><span class="schedule-time">10:00 – 20:00</span>
                            </div>
                        </div>
                    </div>
                    <div style="margin-top: 30px; display: flex; gap: 16px; flex-wrap: wrap;">
                        <a href="https://yandex.ru/maps/-/CPu0nWmW" target="_blank" style="background:#2a2a2a; padding:12px 24px; border-radius:40px; color:#d4a13e; text-decoration:none; display:inline-flex; align-items:center; gap:8px;"><i class="fab fa-yandex"></i> Яндекс Карты</a>
                        <a href="https://wa.me/79636941515" target="_blank" style="background:#25D366; padding:12px 24px; border-radius:40px; color:#fff; text-decoration:none; display:inline-flex; align-items:center; gap:8px;"><i class="fab fa-whatsapp"></i> WhatsApp</a>
                    </div>
                </div>
                <div class="map-container">
                    <iframe src="https://yandex.ru/map-widget/v1/?ll=37.744724%2C55.588347&mode=search&oid=214010422076&ol=biz&z=18.97" width="100%" height="100%" frameborder="0" allowfullscreen="true" style="position:relative;"></iframe>
                </div>
            </div>
        </section>

        <section class="feedback">
            <div class="container">
                <div class="form-card">
                    <h3 style="margin-bottom: 8px;">Остались вопросы?</h3>
                    <p style="color:#aaa;">Оставьте заявку — мы свяжемся в ближайшее время</p>
                    <form id="callbackForm">
                        <div class="form-group">
                            <input type="text" class="form-input" placeholder="Ваше имя" required>
                            <input type="tel" class="form-input" placeholder="Телефон" required>
                            <button type="submit" class="form-btn"><i class="fab fa-whatsapp"></i> Отправить</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <p>© 2025 LuxAutoSpa — детейлинг и автохимчистка. Все права защищены.</p>
        </div>
    </footer>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox">
        <div class="lightbox-close" id="lightboxClose"><i class="fas fa-times"></i></div>
        <div class="lightbox-nav prev" id="lightboxPrev"><i class="fas fa-chevron-left"></i></div>
        <div class="lightbox-nav next" id="lightboxNext"><i class="fas fa-chevron-right"></i></div>
        <div class="lightbox-content">
            <img src="" alt="" class="lightbox-image" id="lightboxImage">
        </div>
        <div class="lightbox-counter" id="lightboxCounter"></div>
    </div>

    <script>
        // Данные для галереи (имитация папки /assets/images/gallery/)
        const galleryImages = [
            '/assets/images/gallery/1.png',
            '/assets/images/gallery/2.png',
            '/assets/images/gallery/3.png',
            '/assets/images/gallery/4.png',
            '/assets/images/gallery/5.png',
            '/assets/images/gallery/6.png',
            '/assets/images/gallery/7.png',
            '/assets/images/gallery/8.png'
        ];

        // Данные услуг
        const categoriesData = [
            {
                "categoryName": "Полировка кузова автомобиля",
                "categoryItems": [
                    { "title": "Полировка - седан, хечбек, универсал", "description": "Цена от 7000", "price": "7000", "currency": "₽" },
                    { "title": "Полировка - джип, внедорожник, паркетник", "description": "Цена от 8000", "price": "8000", "currency": "₽" }
                ]
            },
            {
                "categoryName": "Химчистка салона автомобиля",
                "categoryItems": [
                    { "title": "Химчистка салона - седан, хечбэк, универсал", "description": "Цена от 6000", "price": "6000", "currency": "₽" },
                    { "title": "Химчистка салона - джип, внедорожник, паркетник", "description": "Цена от 7000", "price": "7000", "currency": "₽" }
                ]
            },
            {
                "categoryName": "Покраска автомобиля",
                "categoryItems": [
                    { "title": "Окрас одной детали", "description": "Цена от 10000", "price": "10000", "currency": "₽" },
                    { "title": "Окраска - локально", "description": "Цена от 6000", "price": "6000", "currency": "₽" }
                ]
            },
            {
                "categoryName": "Полировка автостекол",
                "categoryItems": [
                    { "title": "Лобовое стекло", "description": "Цена от 6000", "price": "6000", "currency": "₽" },
                    { "title": "Заднее стекло", "description": "Цена от 5000", "price": "5000", "currency": "₽" },
                    { "title": "Остальные", "description": "Цена от 3000", "price": "3000", "currency": "₽" }
                ]
            },
            {
                "categoryName": "Реставрация салона",
                "categoryItems": [
                    { "title": "Перешивка салона целиком", "description": "Цена от 80000", "price": "80000", "currency": "₽" },
                    { "title": "Перешивка руля", "description": "Цена от 6000", "price": "6000", "currency": "₽" }
                ]
            },
            {
                "categoryName": "Покрытие керамика / стекло",
                "categoryItems": [
                    { "title": "Покрытие - керамика", "description": "Цена от 40000", "price": "40000", "currency": "₽" },
                    { "title": "Покрытие - жидкое стекло", "description": "Цена от 25000", "price": "25000", "currency": "₽" }
                ]
            }
        ];

        // Переменные для lightbox
        let currentImageIndex = 0;
        let currentGallery = [];

        // Инициализация галереи hero
        function initHeroGallery() {
            const mainImage = document.querySelector('#heroMainImage img');
            const thumbnails = document.querySelectorAll('.thumbnail');
            
            thumbnails.forEach((thumb, index) => {
                thumb.addEventListener('click', () => {
                    // Обновляем активный класс
                    document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
                    thumb.classList.add('active');
                    
                    // Обновляем главное изображение
                    const imgSrc = thumb.querySelector('img').src;
                    mainImage.src = imgSrc;
                    
                    // Для lightbox
                    currentImageIndex = index;
                });
            });

            // Клик на главное изображение открывает lightbox
            document.querySelector('#heroMainImage').addEventListener('click', () => {
                currentGallery = galleryImages.slice(0, 4); // Первые 4 фото из hero
                currentImageIndex = Array.from(thumbnails).findIndex(t => t.classList.contains('active'));
                openLightbox(currentImageIndex);
            });
        }

        // Заполнение галереи работ
        function initGalleryGrid() {
            const grid = document.getElementById('galleryGrid');
            galleryImages.forEach((src, index) => {
                const item = document.createElement('div');
                item.className = 'gallery-item';
                item.innerHTML = `<img src="${src}" alt="Gallery image ${index + 1}" onerror="this.src='https://via.placeholder.com/400x300/1e1e1e/d4a13e?text=${index + 1}'">`;
                item.addEventListener('click', () => {
                    currentGallery = galleryImages;
                    currentImageIndex = index;
                    openLightbox(index);
                });
                grid.appendChild(item);
            });
        }

        // Lightbox functions
        function openLightbox(index) {
            const lightbox = document.getElementById('lightbox');
            const lightboxImage = document.getElementById('lightboxImage');
            const counter = document.getElementById('lightboxCounter');
            
            currentImageIndex = index;
            lightboxImage.src = currentGallery[currentImageIndex];
            lightboxImage.classList.remove('zoomed');
            counter.textContent = `${currentImageIndex + 1} / ${currentGallery.length}`;
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('lightbox').classList.remove('active');
            document.body.style.overflow = '';
        }

        function navigateLightbox(direction) {
            currentImageIndex = (currentImageIndex + direction + currentGallery.length) % currentGallery.length;
            const lightboxImage = document.getElementById('lightboxImage');
            const counter = document.getElementById('lightboxCounter');
            
            lightboxImage.src = currentGallery[currentImageIndex];
            lightboxImage.classList.remove('zoomed');
            counter.textContent = `${currentImageIndex + 1} / ${currentGallery.length}`;
        }

        // Рендер услуг
        function renderCategories() {
            const container = document.getElementById('categoriesContainer');
            if (!container) return;
            
            container.innerHTML = '';
            categoriesData.forEach(cat => {
                const block = document.createElement('div');
                block.className = 'category-block';
                block.innerHTML = `<div class="category-name">${cat.categoryName}</div><div class="items-grid"></div>`;
                const grid = block.querySelector('.items-grid');
                
                cat.categoryItems.forEach(item => {
                    const priceValue = item.price;
                    const currency = item.currency;
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.innerHTML = `
                        <div class="service-title">${item.title}</div>
                        <div class="service-desc">${item.description}</div>
                        <div class="price-row">
                            <span class="price">${priceValue} ${currency}</span>
                            <a href="https://wa.me/79636941515?text=Здравствуйте!%20Меня%20интересует:%20${encodeURIComponent(item.title)}%20(цена%20от%20${priceValue}%20${currency})" target="_blank" class="order-btn"><i class="fab fa-whatsapp"></i> Заказать</a>
                        </div>
                    `;
                    grid.appendChild(card);
                });
                container.appendChild(block);
            });
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', () => {
            initHeroGallery();
            initGalleryGrid();
            renderCategories();

            // Lightbox controls
            document.getElementById('lightboxClose').addEventListener('click', closeLightbox);
            document.getElementById('lightboxPrev').addEventListener('click', () => navigateLightbox(-1));
            document.getElementById('lightboxNext').addEventListener('click', () => navigateLightbox(1));
            
            // Зум по клику
            document.getElementById('lightboxImage').addEventListener('click', function(e) {
                this.classList.toggle('zoomed');
            });

            // Зум колесиком
            document.getElementById('lightboxImage').addEventListener('wheel', function(e) {
                e.preventDefault();
                if (e.deltaY < 0) {
                    this.classList.add('zoomed');
                } else {
                    this.classList.remove('zoomed');
                }
            });

            // Закрытие по ESC
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeLightbox();
                if (e.key === 'ArrowLeft') navigateLightbox(-1);
                if (e.key === 'ArrowRight') navigateLightbox(1);
            });

            // Клик вне изображения для закрытия
            document.getElementById('lightbox').addEventListener('click', function(e) {
                if (e.target === this) closeLightbox();
            });
        });

        // Форма обратной связи
        document.getElementById('callbackForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const name = this.querySelector('input[type="text"]').value;
            const phone = this.querySelector('input[type="tel"]').value;
            if(name && phone) {
                const text = `Здравствуйте! Меня зовут ${name}. Мой телефон: ${phone}. Прошу связаться со мной.`;
                window.open(`https://wa.me/79636941515?text=${encodeURIComponent(text)}`, '_blank');
            } else {
                alert('Заполните имя и телефон');
            }
        });
    </script>
</body>
</html>